{
    "name": "my-app",
    "version": "0.17.0",
    "private": true,
    "description": "npm init template for bootstrapping an empty Colyseus project",
    "homepage": "https://github.com/colyseus/create-colyseus#readme",
    "bugs": {
        "url": "https://github.com/colyseus/create-colyseus/issues"
    },
    "license": "UNLICENSED",
    "author": "",
    "type": "module",
    "main": "build/index.js",
    "scripts": {
        "start": "tsx watch src/index.ts",
        "dev": "tsx watch src/index.ts",
        "loadtest": "tsx loadtest/example.ts --room my_room --numClients 2",
        "build": "npm run clean && tsc -p tsconfig.build.json",
        "clean": "rimraf build",
        "test": "mocha -r tsx test/**.test.ts --exit --timeout 15000",
        "Syntax And Format": "------------------------------------",
        "lint": "oxlint",
        "lint:fix": "oxlint --fix",
        "lint:fixsugg": "oxlint --fix-suggestions",
        "fmt": "oxfmt",
        "fmt:check": "oxfmt --check",
        "oxmint": "oxlint",
        "oxfmt": "oxfmt",
        "full:check": "yarn lint:fix & yarn lint:fix"
    },
    "dependencies": {
        "@colyseus/schema": "^4.0.0",
        "@colyseus/tools": "^0.17.0",
        "colyseus": "^0.17.6",
        "dotenv": "^17.4.2",
        "express": "^4.18.2",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@colyseus/loadtest": "^0.17.7",
        "@colyseus/sdk": "^0.17.17",
        "@colyseus/testing": "^0.17.10",
        "@types/express": "^4.17.1",
        "@types/mocha": "^10.0.1",
        "mocha": "^11.7.5",
        "oxfmt": "^0.53.0",
        "oxlint": "^1.68.0",
        "rimraf": "^5.0.0",
        "tsx": "^4.21.0",
        "typescript": "^5.0.4",
        "vitest": "^4.1.8"
    },
    "engines": {
        "node": ">= 20.9.0"
    }
}
